MEMORIA_USER_AGENT=MEMORIA-Seismic-Observatory/0.1 contact@example.org
MEMORIA_REQUEST_TIMEOUT=45
MEMORIA_DATA_ROOT=data

# Use the Windows/macOS/Linux operating-system certificate store.
MEMORIA_USE_SYSTEM_TRUST_STORE=true

# Optional: path to a PEM bundle supplied by your organisation.
# MEMORIA_CA_BUNDLE=C:\certificates\enterprise-root-chain.pem

# Keep true. False is only an unsafe temporary diagnostic option.
MEMORIA_SSL_VERIFY=true

# Optional explanatory chatbot powered by Mistral Chat Completions.
MEMORIA_ASSISTANT_ENABLED=true
MISTRAL_API_KEY=
MEMORIA_MISTRAL_MODEL=mistral-small-latest
MEMORIA_MISTRAL_BASE_URL=https://api.mistral.ai/v1
MEMORIA_MISTRAL_TIMEOUT=45
MEMORIA_MISTRAL_MAX_TOKENS=700
MEMORIA_MISTRAL_TEMPERATURE=0.15
MEMORIA_MISTRAL_MAX_RETRIES=2
MEMORIA_ASSISTANT_MAX_HISTORY=8
